# Your published container image, for example:
# WATCHTOGEATHER_IMAGE=ghcr.io/coop25/watchparty-server:v1.0.0
WATCHTOGEATHER_IMAGE=ghcr.io/coop25/watchparty-server:v1.0.0

# Create a named Cloudflare Tunnel in the dashboard and copy its token here.
CLOUDFLARE_TUNNEL_TOKEN=replace-with-your-tunnel-token

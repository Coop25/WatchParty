{
  "manifest_version": 3,
  "name": "WatchTogether MVP",
  "version": "0.1.0",
  "description": "Synchronize HTML5 video playback across multiple clients.",
  "permissions": ["storage", "tabs", "webRequest", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
